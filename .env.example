COOL_PAPER_NOTIFY=none
COOL_PAPER_TIMEZONE=Asia/Shanghai
COOL_PAPER_CATEGORIES="cs.AI cs.CL cs.CV"

# Scheduled jobs use local Codex by default.
COOL_PAPER_DAILY_CLASSIFIER=codex
COOL_PAPER_HF_CLASSIFIER=codex
# Optional Codex overrides.
# COOL_PAPER_CODEX_MODEL=gpt-5-codex
# COOL_PAPER_CODEX_TIMEOUT_SECONDS=900

# Auto-push generated reports/site data after each scheduled update.
COOL_PAPER_GIT_REMOTE=origin
# Leave empty to use the current checked-out branch.
COOL_PAPER_GIT_BRANCH=

# Email push config. Only needed when COOL_PAPER_NOTIFY=email.
COOL_PAPER_SMTP_HOST=smtp.example.com
COOL_PAPER_SMTP_PORT=587
COOL_PAPER_SMTP_SECURITY=starttls
COOL_PAPER_SMTP_USERNAME=your_account@example.com
COOL_PAPER_SMTP_PASSWORD=your_app_password
COOL_PAPER_EMAIL_FROM=your_account@example.com
COOL_PAPER_EMAIL_TO=your_account@example.com
